{
  "id": "http://justice.gov.uk/v24/progression/events/public.progression.offence.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "offenceCode": {
      "type": "string"
    },
    "wording": {
      "type": "string"
    },
    "startDate": {
      "$ref": "#/definitions/datePattern"
    },
    "endDate": {
      "$ref": "#/definitions/datePattern"
    },
    "count": {
      "type": "integer"
    },
    "convictionDate": {
      "$ref": "#/definitions/datePattern"
    },
    "statementOfOffence": {
      "$ref": "http://justice.gov.uk/v24/listing/events/statementOfOffence.json"
    }
  },
  "required": [
    "id"
  ],
  "definitions":{
    "datePattern":{
      "type":"string",
      "pattern":"^((([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13578]|1[02])\\-(0[1-9]|[12]\\d|3[01]))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13456789]|1[012])\\-(0[1-9]|[12]\\d|30))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-02\\-(0[1-9]|1\\d|2[0-8]))|(((1[6-9]|[2-9]\\d)(0[48]|[2468][048]|[13579][26])|((16|[2468][048]|[3579][26])00))\\-02\\-29))$"
    }
  }
}
