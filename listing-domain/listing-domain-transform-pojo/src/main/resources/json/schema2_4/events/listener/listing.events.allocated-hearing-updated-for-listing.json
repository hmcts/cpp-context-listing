{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/v24/listing/events/listing.events.allocated-hearing-updated-for-listing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "jurisdictionType": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/jurisdictionType"
    },
    "judiciary": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/v24/listing/events/judicialRole.json"
      }
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "type": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/hearingType"
    },
    "reportingRestrictionReason": {
      "type": "string"
    },
    "hearingLanguage": {
      "$ref": "http://justice.gov.uk/v24/listing/events/listing-definitions.json#/definitions/hearingLanguage"
    },
    "prosecutionCaseDefendantsOffenceIds": {
      "type": "array",
      "minItems": 1,
      "items": [
        {
          "$ref": "http://justice.gov.uk/v24/listing/events/prosecution-case-defendant-offence-ids.json"
        }
      ]
    },

    "estimatedMinutes": {
      "type": "integer"
    },
    "hearingDays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/v24/listing/events/hearingDay.json"
      }
    }
  },
  "required": [
    "hearingId",
    "type",
    "jurisdictionType",
    "hearingLanguage",
    "hearingDays",
    "courtCentreId",
    "courtRoomId",
    "prosecutionCaseDefendantsOffenceIds"
  ],
  "additionalProperties": false
}
