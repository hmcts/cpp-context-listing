{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/courtApplication.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "linkedCaseId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "parentApplicationId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "respondents": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/applicantRespondent.json"
      }
    },
    "applicant": {
           "$ref": "http://justice.gov.uk/listing/events/applicantRespondent.json"
    },
    "applicationType": {
      "type": "string"
    },
    "restrictFromCourtList": {
      "type":"boolean"
    },
    "restrictCourtApplicationType": {
      "type":"boolean"
    },
    "courtApplicationPartyType": {
      "description": "The type of court application party",
      "type": "string",
      "enum": [
        "PERSON",
        "ORGANISATION",
        "PROSECUTING_AUTHORITY",
        "PERSON_DEFENDANT"
      ]
    }
  },
  "required": [
    "id",
    "applicant",
    "applicationType"
  ],
  "additionalProperties": false
}
