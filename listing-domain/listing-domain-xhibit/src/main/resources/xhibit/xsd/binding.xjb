<?xml version="1.0" encoding="UTF-8"?>
<jaxb:bindings xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:xjc="http://java.sun.com/xml/ns/jaxb/xjc" xmlns="http://java.sun.com/xml/ns/jaxws"
               xmlns:namespace="http://jaxb2-commons.dev.java.net/namespace-prefix"
               jaxb:version="2.0">

  <jaxb:globalBindings>
    <xjc:javaType xmlType="xs:date" name="java.time.LocalDate"
                  adapter="uk.gov.moj.cpp.listing.domain.xhibit.LocalDateAdapter"/>
  </jaxb:globalBindings>
  <jaxb:bindings schemaLocation = "1_CourtService.xsd"    node="//xs:complexType[@name='CustodialTermStructure']//xs:attribute[@name='Section44']">
       <jaxb:property name="Section440"/>
  </jaxb:bindings>

  <jaxb:bindings  schemaLocation = "DailyList.xsd"  >
    <jaxb:bindings>
      <namespace:prefix name="xsi" namespaceURI="http://www.w3.org/2001/XMLSchema-instance" />
      <namespace:prefix name="cs" namespaceURI="http://www.courtservice.gov.uk/schemas/courtservice" />
      <namespace:prefix name="apd" namespaceURI="http://www.govtalk.gov.uk/people/AddressAndPersonalDetails" />
      <namespace:prefix name="p2" namespaceURI="http://www.govtalk.gov.uk/people/bs7666" />
    </jaxb:bindings>
  </jaxb:bindings>

</jaxb:bindings>