@startuml
title Court List Publishing v1 (single court site per XML file)
ui.listing -> ListingCommandApi: listing.command.publish-court-list
ListingCommandApi -> ListingCommandHandler: listing.command.publish-court-list
ListingCommandHandler -> CourtListEventListener: listing.event.publish-court-list-requested
CourtListEventListener -> ListingViewStore: updateStatus(COURT_LIST_REQUESTED)
ListingCommandHandler -> CourtListEventProcessor: listing.event.publish-court-list-requested
CourtListEventProcessor -> ListingQueryView: getHearings
CourtListEventProcessor -> CourtListEventProcessor: generateXmlCourtListForCourtSite()
CourtListEventProcessor -> FileService: storeFile()
CourtListEventProcessor -> ListingCommandHandler: listing.command.record-court-list-produced
ListingCommandHandler -> CourtListEventListener: listing.event.publish-court-list-produced
CourtListEventListener -> ListingViewStore: updateStatus(COURT_LIST_PRODUCED)
ListingCommandHandler -> CourtListEventProcessor: listing.event.publish-court-list-produced
CourtListEventProcessor -> XhibitService: sendToExhibit
XhibitService -> FileService: retrieveFile()
XhibitService -> WebDAV: PUT file
CourtListEventProcessor -> ListingCommandHandler :listing.command.record-court-list-export-successful
ListingCommandHandler ->  CourtListEventListener: listing.event.publish-court-list-export-successful
CourtListEventListener -> ListingViewStore: updateStatus(EXPORT_SUCCESSFUL)
@enduml
