<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <parent>
        <groupId>uk.gov.moj.cpp.common</groupId>
        <artifactId>service-parent-pom</artifactId>
        <version>4.0.16</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <groupId>uk.gov.moj.cpp.listing</groupId>
    <artifactId>listing-parent</artifactId>
    <version>0.0.2-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Listing Context Microservice Parent</name>

    <description>
        The listing microservice is a Listing context based microservice that processes CPP
        cases to be listed for hearing(s). Once the hearing is fully allocated it emits this
        event to downstream CPP contexts.
    </description>

    <properties>
        <activiti.library.version>1.0.0</activiti.library.version>
    </properties>

    <modules>
        <module>listing-command</module>
        <module>listing-domain</module>
        <module>listing-event</module>
        <module>listing-integration-test</module>
        <module>listing-query</module>
        <module>listing-viewstore</module>
    </modules>

    <dependencyManagement>
        <dependencies>
            <!-- TODO: Move this to service parent pom -->
            <dependency>
                <groupId>uk.gov.moj.cpp.activiti</groupId>
                <artifactId>activiti-embedded-rest</artifactId>
                <version>${activiti.library.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>external.atlassian.jgitflow</groupId>
                <artifactId>jgitflow-maven-plugin</artifactId>
                <version>1.0-m5.1</version>
                <configuration>
                    <flowInitContext>
                        <masterBranchName>dev/listing-release</masterBranchName>
                        <developBranchName>master</developBranchName>
                        <featureBranchPrefix>dev/listing-feature-</featureBranchPrefix>
                        <releaseBranchPrefix>dev/listing-release-</releaseBranchPrefix>
                        <hotfixBranchPrefix>dev/listing-hotfix-</hotfixBranchPrefix>
                        <versionTagPrefix>listing-tag-</versionTagPrefix>
                    </flowInitContext>
                    <autoVersionSubmodules>true</autoVersionSubmodules>
                    <enableSshAgent>true</enableSshAgent>
                    <pushReleases>true</pushReleases>
                </configuration>
            </plugin>

        </plugins>
    </build>
</project>