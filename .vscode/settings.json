{
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.compile.nullAnalysis.mode": "automatic",
    "java.test.config": {
        "vmargs": [
            "-Djava.awt.headless=true",
            "-Dfile.encoding=UTF-8"
        ],
        "workingDirectory": "${workspaceFolder}"
    },
    "java.project.sourcePaths": [
        "src/main/java",
        "target/generated-sources/annotations",
        "target/generated-test-sources/test-annotations"
    ],
    "java.project.outputPath": "target/classes",
    "java.project.referencedLibraries": [
        "lib/**/*.jar",
        "target/generated-sources/annotations",
        "target/generated-test-sources/test-annotations"
    ],
    "java.import.maven.enabled": true,
    "java.maven.downloadSources": true,
    "java.debug.settings.hotCodeReplace": "auto",
    "java.completion.enabled": true,
    "java.signatureHelp.enabled": true,
    "java.contentProvider.preferred": "fernflower",
    "java.cleanup.actions": [
        "addOverride",
        "qualifyStaticMembers",
        "qualifyMembers",
        "addDeprecated",
        "stringConcatenation",
        "invertEquals",
        "hashCodeEquals",
        "arrayToString",
        "toArray",
        "instanceof",
        "switch",
        "unnecessaryThis",
        "unnecessaryElse",
        "unnecessaryCast",
        "unnecessaryReturn",
        "collectionCloning",
        "mapCloning",
        "indexOfReplaceableByContains",
        "assertThrows",
        "tryWithResource",
        "explicitArgumentMatcher",
        "boxing",
        "unboxing",
        "pushDownNegation",
        "pullUpNegation",
        "removeComparisonWithNaN",
        "removeRedundantTypeArguments",
        "removeRedundantModifiers",
        "removeRedundantCasts",
        "removeRedundantArrayCreation",
        "removeRedundantSemicolons",
        "removeRedundantThrows",
        "removeRedundantLabels",
        "removeRedundantLocalVariables",
        "removeRedundantAllocation",
        "removeRedundantConditions",
        "removeRedundantNullnessAnnotations",
        "removeRedundantAssertion",
        "removeRedundantCollectionOperation",
        "removeRedundantStringOperation",
        "removeRedundantCode",
        "removeRedundantTypeCasts",
        "removeRedundantTypeArguments",
        "removeRedundantModifiers",
        "removeRedundantCasts",
        "removeRedundantArrayCreation",
        "removeRedundantSemicolons",
        "removeRedundantThrows",
        "removeRedundantLabels",
        "removeRedundantLocalVariables",
        "removeRedundantAllocation",
        "removeRedundantConditions",
        "removeRedundantNullnessAnnotations",
        "removeRedundantAssertion",
        "removeRedundantCollectionOperation",
        "removeRedundantStringOperation",
        "removeRedundantCode"
    ],
    "testing.automaticallyOpenPeekView": "never",
    "testing.openTesting": "openOnTestStart",
    "testing.followRunningTest": true,
    "testing.gutterEnabled": true,
    "testing.automaticallyOpenTestResults": "openOnTestStart",
    "explorer.decorations.badges": true,
    "explorer.decorations.colors": true,
    "workbench.editor.decorations.badges": true,
    "diffEditor.experimental.showEmptyDecorations": true,
    "scm.diffDecorations": "all",
    "git.blame.editorDecoration.enabled": true,
    "git.blame.editorDecoration.template": "${subject}, ${authorName} (${authorDateAgo})",
    "java.saveActions.organizeImports": true,
    "problems.visibility": false,
    "java.dependency.packagePresentation": "flat",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "java.project.explorer.showNonJavaResources": true,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.suggest.enabled": true,
    "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms100m -Xlog:disable"
}