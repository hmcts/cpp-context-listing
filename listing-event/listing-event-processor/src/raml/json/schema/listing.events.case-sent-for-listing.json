{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.case-sent-for-listing.json",
  "type": "object",
  "properties": {
    "caseId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "urn": {
      "type": "string",
      "maxLength": 15
    },
    "hearings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/hearing.json"
      }
    }
  },
  "required": [
    "caseId",
    "urn",
    "hearings"
  ],
  "additionalProperties": false
}
