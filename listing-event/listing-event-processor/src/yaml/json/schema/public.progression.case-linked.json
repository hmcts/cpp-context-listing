{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/progression/courts/case-linked.json",
  "type": "object",
  "properties": {
    "linkActionType": {
      "type": "string",
      "enum": [
        "LINK",
        "UNLINK"
      ]
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "caseId": {
            "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
          },
          "caseUrn": {
            "type": "string"
          },
          "linkedToCases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "caseId": {
                  "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
                },
                "caseUrn": {
                  "type": "string"
                }
              },
              "required": [
                "caseId",
                "caseUrn"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "caseId",
          "caseUrn",
          "linkedToCases"
        ],
        "additionalProperties": false
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "required": [
    "linkActionType",
    "cases"
  ]
}