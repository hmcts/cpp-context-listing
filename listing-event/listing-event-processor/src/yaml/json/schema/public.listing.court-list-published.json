{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/events/court-list-published.json",
  "type": "object",
  "properties": {
    "courtListId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "requestedTime": {
      "type": "string",
      "format": "date-time"
    },
    "startDate": {
      "$ref": "#/definitions/localDate"
    },
    "endDate": {
      "$ref": "#/definitions/localDate"
    },
    "weekCommencing": {
      "type": "boolean"
    },
    "courtLists": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/courtList"
      }
    },
    "sendNotificationToParties": {
      "type": "boolean"
    }
  },
  "required": [
    "courtListId",
    "courtCentreId",
    "publishCourtListType",
    "requestedTime",
    "startDate",
    "endDate",
    "weekCommencing",
    "courtLists"
  ],
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    },
    "courtList": {
      "type": "object",
      "properties": {
        "sittingDate": {
          "$ref": "#/definitions/localDate"
        },
        "weekCommencing": {
          "type": "boolean"
        },
        "courtRoomId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "judiciary": {
          "type": "array",
          "items": {
            "$ref": "http://justice.gov.uk/listing/events/judicialRole.json"
          }
        },
        "hearings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startTime": {
                "type": "string"
              },
              "endTime": {
                "type": "string"
              },
              "hearingType": {
                "$ref": "http://justice.gov.uk/core/courts/hearingType.json"
              },
              "restrictFromCourtList": {
                "type": "boolean",
                "default": false
              },
              "weekCommencing": {
                "type": "boolean"
              },
              "hasVideoLink": {
                "type": "boolean"
              },
              "committingCourtCentreId": {
                "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
              },
              "caseIdentifier": {
                "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/caseIdentifier"
              },
              "defendants": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "http://justice.gov.uk/core/courts/defendant.json"
                }
              }
            },
            "required": [
              "hearingType"
            ]
          }
        }
      },
      "required": [
        "sittingDate",
        "judiciary",
        "hearings"
      ]
    }
  }
}