{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.hearing-unallocated-for-listing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "judgeId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "type": {
      "type": "string"
    },

    "estimateMinutes": {
      "type": "integer"
    },
    "hearingDate": {
      "type": "object",
      "properties": {
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "startTime": {
          "type": "string",
          "format": "time"
        }
      },
      "required": [
        "startDate"
      ]
    }
  },
  "required": [
    "hearingId",
    "type",
    "estimateMinutes",
    "hearingDate"
  ],
  "additionalProperties": false
}
