{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/event/listing.event.published-court-list-stored.json",
  "type": "object",
  "properties": {
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "startDate": {
      "$ref": "#/definitions/localDate"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "courtListJson": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "courtCentreId",
    "startDate",
    "publishCourtListType",
    "courtListJson",
    "lastUpdated"
  ],
  "additionalProperties": false,
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    }
  }
}
