{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/application-ejected.json",
  "type": "object",
  "properties": {
    "hearingIds":{
      "type": "array",
      "minItems": 1,
      "items":{
        "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
      }
    },
    "applicationId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "removalReason": {
      "type": "string"
    }
  },
  "required": [
    "applicationId",
    "removalReason"
  ],
  "additionalProperties": false
}
