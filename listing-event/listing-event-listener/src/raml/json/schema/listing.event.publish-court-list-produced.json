{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/event/listing.event.publish-court-list-produced.json",
  "type": "object",
  "properties": {
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileName": {
      "type": "string"
    },
    "courtListType": {
      "type": "string"
    },
    "producedTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "required": [
    "courtCentreId",
    "courtListFileId",
    "courtListFileName",
    "courtListType",
    "producedTime"
  ]
}