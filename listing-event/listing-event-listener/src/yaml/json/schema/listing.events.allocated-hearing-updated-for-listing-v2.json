{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.allocated-hearing-updated-for-listing-v2.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "jurisdictionType": {
      "$ref": "http://justice.gov.uk/core/courts/jurisdictionType.json"
    },
    "judiciary": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/judicialRole.json"
      }
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "type": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/hearingType"
    },
    "reportingRestrictionReason": {
      "type": "string"
    },
    "hearingLanguage": {
      "$ref": "http://justice.gov.uk/core/courts/hearingLanguage.json"
    },
    "prosecutionCaseDefendantsOffenceIds": {
      "type": "array",
      "minItems": 1,
      "items": [
        {
          "$ref": "http://justice.gov.uk/listing/events/prosecution-case-defendant-offence-ids-v2.json"
        }
      ]
    },

    "estimatedMinutes": {
      "type": "integer"
    },
    "courtApplicationIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
      }
    },
    "hearingDays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/hearingDay.json"
      }
    },
    "updateSlot":{
      "type" : "boolean"
    },
    "source": {
      "type": "string"
    },
    "sendNotificationToParties": {
      "type": "boolean"
    },
    "isNotificationAllocationFieldUpdated": {
      "type" : "boolean"
    }
  },
  "required": [
    "hearingId",
    "type",
    "jurisdictionType",
    "hearingLanguage",
    "hearingDays",
    "courtCentreId",
    "courtRoomId"
  ],
  "additionalProperties": false
}
