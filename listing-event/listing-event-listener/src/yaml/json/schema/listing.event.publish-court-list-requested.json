{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/event/listing.event.publish-court-list-requested.json",
  "type": "object",
  "properties": {
    "publishCourtListRequestId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "endDate": {
      "type": "string",
      "format": "date"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "publishStatus": {
      "type": "string",
      "enum": [
        "EXPORT_FAILED",
        "EXPORT_SUCCESSFUL",
        "COURT_LIST_REQUESTED",
        "COURT_LIST_PRODUCED",
        "INVALID_STATUS"
      ]
    },
    "requestedTime": {
      "type": "string",
      "format": "date-time"
    },
    "weekCommencing": {
      "type": "boolean",
      "default": false
    },
    "sendNotificationToParties": {
      "type": "boolean"
    }
  },
  "required": [
    "publishCourtListRequestId",
    "courtCentreId",
    "startDate",
    "endDate",
    "publishCourtListType",
    "publishStatus",
    "requestedTime"
  ],
  "additionalProperties": false
}
