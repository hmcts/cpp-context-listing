{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.offences-removed-from-hearing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "seedingHearingId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "caseIdsSeededByOnlySeedingHearingId": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
      }
    },
    "seededOffences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
      }
    },
    "unallocated": {
      "type": "boolean",
      "description": "If the hearing needs to be unallocated"
    }
  },
  "required": [
    "hearingId",
    "seedingHearingId",
    "seededOffences"
  ],
  "additionalProperties": false
}
