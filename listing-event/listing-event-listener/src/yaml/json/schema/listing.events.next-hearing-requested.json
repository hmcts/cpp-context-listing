{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.next-hearing-requested.json",
  "type": "object",
  "properties": {
    "hearing": {
      "$ref": "http://justice.gov.uk/listing/commands/hearingListingNeeds.json"
    },
    "courtCentreDetails": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/court-centre-details.json"
      }
    },
    "adjournedFromDate": {
      "description": "Adjournment date",
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/datePattern"
    },
    "shadowListedOffences": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
      }
    },
    "hearingDay": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/datePattern"
    }
  },
  "required": [
    "hearing",
    "courtCentreDetails",
    "hearingDay"
  ],
  "definitions": {
    "courtApplicationPartyListingNeeds": {
      "id": "http://justice.gov.uk/core/courts/courtApplicationPartyListingNeeds.json",
      "type": "object",
      "properties": {
        "courtApplicationId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "courtApplicationPartyId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "hearingLanguageNeeds": {
          "$ref": "http://justice.gov.uk/core/courts/hearingLanguage.json"
        }
      },
      "required": [
        "courtApplicationId",
        "courtApplicationPartyId"
      ],
      "additionalProperties": false
    },
    "defendantListingNeeds": {
      "id": "http://justice.gov.uk/core/courts/defendantListingNeeds.json",
      "type": "object",
      "properties": {
        "prosecutionCaseId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "defendantId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "datesToAvoid": {
          "type": "string"
        },
        "isYouth": {
          "description": "Indicates that the defendant must be dealt with as a Youth for listing purposes.  This is calculated based on teh requested listing date compared to date of birth",
          "type": "boolean"
        },
        "listingReason": {
          "type": "string"
        },
        "hearingLanguageNeeds": {
          "$ref": "http://justice.gov.uk/core/courts/hearingLanguage.json"
        }
      },
      "required": [
        "prosecutionCaseId",
        "defendantId"
      ]
    }
  },
  "additionalProperties": false
}


