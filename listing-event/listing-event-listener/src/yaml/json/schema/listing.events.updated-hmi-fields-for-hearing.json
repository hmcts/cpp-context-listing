{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.updated-hmi-fields-for-hearing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "bookingType": {
      "description": "A choice of in-court, or video conference options",
      "type": "string"
    },
    "priority": {
      "description": "Priority marking on hearings/cases",
      "type": "string"
    },
    "specialRequirements": {
      "description": "Special requirements on hearings/cases",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "hearingId"
  ],
  "additionalProperties": false
}
