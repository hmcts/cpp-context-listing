<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet author="listing" id="1" logicalFilePath="004-GPE-5524.xml">

        <dropTable tableName="offence"/>
        <dropTable tableName="defendant"/>
        <dropTable tableName="hearing"/>
        <dropTable tableName="listing_case"/>

        <createTable tableName="hearing">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="properties" type="jsonb"/>
        </createTable>

        <sql>CREATE INDEX idx_allocated ON hearing USING GIN ((properties -> 'courtCentreId'), (properties -> 'allocated'))</sql>

    </changeSet>

</databaseChangeLog>
