<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet id="10" author="listing" logicalFilePath="010-SCSL-258.xml">
        <createTable tableName="published_court_list">
            <column name="court_centre_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="publish_court_list_type" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="court_list_json" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="last_exported" type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addPrimaryKey
                columnNames="court_centre_id, publish_court_list_type, start_date"
                constraintName="pk_published_court_list"
                tableName="published_court_list"
        />

    </changeSet>
</databaseChangeLog>
