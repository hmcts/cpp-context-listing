{
  "type": "object",
  "id": "http://justice.gov.uk/listing/commands/listing.command.update-offences-for-hearing.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "caseId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "defendantId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "offences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/commands/offence.json"
      }
    }
  },
  "required": [
    "hearingId",
    "caseId",
    "defendantId",
    "offences"
  ],
  "additionalProperties": false
}