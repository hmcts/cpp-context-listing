{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/update-hearings-for-listing-enriched.json",
  "type": "object",
  "properties": {
    "updateHearingsForListing": {
      "description": "Enriched updated hearings for listings",
      "type": "array",
      "minItems": 1,
      "items": {
        "properties": {
          "updateHearingForListing": {
            "$ref": "http://justice.gov.uk/listing/commands/listing.command.handler.update-hearing-for-listing.json"
          },
          "courtCentreDetails": {
            "$ref": "http://justice.gov.uk/listing/commands/court-centre-details.json"
          },
          "prosecutionCases": {
            "description": "Prosecution cases to be added in allocated hearing",
            "type": "array",
            "minItems": 1,
            "items": {
              "properties": {
                "caseId": {
                  "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
                },
                "defendants": {
                  "description": "Defendants to be added in allocated hearing",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "properties": {
                      "defendantId": {
                        "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
                      },
                      "offences": {
                        "description": "Offences to be added in allocated hearing",
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "properties": {
                            "offenceId": {
                              "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
                            }
                          },
                          "required": [
                            "offenceId"
                          ],
                          "additionalProperties": false
                        }
                      }
                    },
                    "required": [
                      "offences"
                    ],
                    "additionalProperties": false
                  }
                }
              },
              "required": [
                "defendants"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "updateHearingForListing",
          "courtCentreDetails"
        ]
      }
    }
  },
  "additionalProperties": false
}

