{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.record-court-list-produced.json",
  "type": "object",
  "properties": {
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileName": {
      "type": "string"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "publishStatus": {
      "type": "string",
      "enum": [
        "EXPORT_FAILED",
        "EXPORT_SUCCESSFUL",
        "COURT_LIST_REQUESTED",
        "COURT_LIST_PRODUCED"
      ]
    },
    "producedTime": {
      "type": "string",
      "format": "date-time"
    },
    "publishDate": {
      "type": "string",
      "format": "date"
    },
    "weekCommencing": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false,
  "required": [
    "courtCentreId",
    "courtListFileId",
    "courtListFileName",
    "publishCourtListType",
    "publishStatus",
    "producedTime",
    "publishDate"
  ]
}