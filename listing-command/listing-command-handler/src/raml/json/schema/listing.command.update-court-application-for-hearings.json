{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/listing.command.update-court-application-for-hearings.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "courtApplication": {
      "$ref": "#/definitions/courtApplication"
    },
    "hearingIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
      }
    }
  },
  "required": [
    "courtApplication",
    "hearingIds"
  ],
  "definitions": {
    "courtApplication": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "linkedCaseId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "parentApplicationId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "applicant": {
          "type": "object",
          "properties": {
            "firstName": {
              "description": "The person first name",
              "type": "string"
            },
            "lastName": {
              "description": "The person last name",
              "type": "string"
            }
          },
          "required": [
            "lastName",
            "isRespondent"
          ]
        },
        "applicationType": {
          "type": "string"
        },
        "applicationReference": {
          "type": "string"
        },
        "respondents": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "properties": {
              "firstName": {
                "description": "The person first name",
                "type": "string"
              },
              "lastName": {
                "description": "The person last name",
                "type": "string"
              }
            },
            "required": [
              "lastName",
              "isRespondent"
            ]
          }
        }
      },
      "required": [
        "id",
        "applicant",
        "applicationType"
      ],
      "additionalProperties": false
    }
  }
}
