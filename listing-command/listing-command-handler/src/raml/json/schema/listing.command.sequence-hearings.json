{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/sequence-hearings.json",
  "type": "object",
  "properties": {
    "hearings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/hearing"
      }
    }
  },
  "required": [
    "hearings"
  ],
  "additionalProperties": false,
  "definitions": {
    "hearing": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "sequenceHearingDays": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "http://justice.gov.uk/listing/commands/sequence-hearing-day.json"
          }
        }
      },
      "required": [
        "id",
        "sequenceHearingDays"
      ],
      "additionalProperties": false
    }
  }
}