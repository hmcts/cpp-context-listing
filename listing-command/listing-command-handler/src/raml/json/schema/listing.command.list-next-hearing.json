{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/listing.command.list-next-hearing.json",
  "type": "object",
  "properties": {
    "hearing": {
      "$ref": "http://justice.gov.uk/listing/commands/hearingListingNeeds.json"
    },
    "courtCentresDetails": {
    "type": "array",
    "minItems": 1,
    "items": {
      "$ref": "http://justice.gov.uk/listing/commands/court-centre-details.json"
    }
  },
    "adjournedFromDate": {
      "description": "Adjournment date",
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/datePattern"
    },
    "shadowListedOffences": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
      }
    }
  },
  "required": [
    "hearing"
  ],
  "additionalProperties": false
}