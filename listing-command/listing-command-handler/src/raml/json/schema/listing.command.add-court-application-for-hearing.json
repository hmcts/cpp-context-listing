{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/listing.command.add-court-application-for-hearing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "courtApplication": {
      "description": "The court application that is be added to the existing listing",
      "$ref": "http://justice.gov.uk/core/courts/courtApplication.json#"
    },
    "prosecutionCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/prosecutionCase.json#"
	  }
    }
  },
  "required": [
    "hearingId",
    "courtApplication"
  ],
  "additionalProperties": false
}
