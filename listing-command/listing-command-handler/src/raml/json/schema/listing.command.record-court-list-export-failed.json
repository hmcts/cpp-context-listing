{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.record-court-list-export-failed.json",
  "type": "object",
  "properties": {
    "publishCourtListRequestId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "failedTime": {
      "type": "string",
      "format": "date-time"
    },
    "errorMessage": {
      "type": "string"
    },
    "weekCommencing": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "publishCourtListRequestId",
    "failedTime",
    "errorMessage"
  ],
  "additionalProperties": false
}
