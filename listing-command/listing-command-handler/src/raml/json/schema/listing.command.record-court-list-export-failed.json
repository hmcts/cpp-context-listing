{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.record-court-list-export-failed.json",
  "type": "object",
  "properties": {
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtListFileName": {
      "type": "string"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "failedTime": {
      "type": "string",
      "format": "date-time"
    },
    "errorMessage": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date"
    },
    "weekCommencing": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "courtCentreId",
    "courtListFileId",
    "courtListFileName",
    "publishCourtListType",
    "failedTime",
    "errorMessage",
    "publishDate"
  ],
  "additionalProperties": false
}
