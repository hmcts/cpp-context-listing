{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.record-court-list-export-failed.json",
  "type": "object",
  "properties": {
    "courtHouseId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "documentId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "documentName": {
      "type": "string"
    },
    "failedTime": {
      "type": "string",
      "format": "date-time"
    },
    "errorMessage": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "courtHouseId",
    "documentId",
    "documentName",
    "failedTime",
    "errorMessage"
  ]
}
