{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.record-court-list-export-failed.json",
  "type": "object",
  "properties": {
    "courtListId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "startDate": {
      "$ref": "#/definitions/localDate"
    },
    "publishCourtListType": {
      "type": "string",
      "enum": [
        "WARN",
        "DRAFT",
        "FIRM",
        "FINAL"
      ]
    },
    "failedTime": {
      "type": "string",
      "format": "date-time"
    },
    "errorMessage": {
      "type": "string"
    }
  },
  "required": [
    "courtListId",
    "courtCentreId",
    "startDate",
    "publishCourtListType",
    "failedTime",
    "errorMessage"
  ],
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
