{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/courts/listing.command.add-cases-for-hearing.json",
  "type": "object",
  "properties": {
    "hearingId": {
	  "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
    },
    "prosecutionCases": {
	  "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/prosecutionCase.json#"
      }
    }
  },
  "required": [
    "hearingId",
    "prosecutionCases"
  ],
  "additionalProperties": false
}
