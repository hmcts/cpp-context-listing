{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/listing.events.hearing-allocated-for-listing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "judgeId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "type": {
      "type": "string"
    },
    "caseId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "urn": {
      "type": "string"
    },

    "defendantsOffenceIds": {
      "type": "array",
      "minItems": 1,
      "items": [
        {
          "$ref": "http://justice.gov.uk/listing/events/defendant-offence-ids.json"
        }
      ]
    },

    "estimateMinutes": {
      "type": "integer"
    },
    "hearingDays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "date-time"
      }
    },
    "hearingDate": {
      "type": "object",
      "properties": {
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "startTime": {
          "type": "string",
          "format": "time"
        }
      },
      "required": [
        "startDate"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "hearingId",
    "type",
    "judgeId",
    "courtRoomId",
    "courtCentreId",
    "caseId",
    "urn",
    "estimateMinutes",
    "hearingDate",
    "hearingDays",
    "defendantsOffenceIds"
  ],
  "additionalProperties": false
}
