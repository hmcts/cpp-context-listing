rule "Command - API - Action - listing.command.publish-court-list"
  when
    $outcome: Outcome();
    $action: Action(name == "listing.command.publish-court-list");
    eval(userAndGroupProvider.isMemberOfAnyOfTheSuppliedGroups($action, RuleConstants.LISTING_OFFICERS, RuleConstants.CROWN_COURT_ADMIN, RuleConstants.COURT_ADMINISTRATORS, RuleConstants.COURT_CLERKS, RuleConstants.LEGAL_ADVISERS));
