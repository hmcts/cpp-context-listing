{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "offences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/simple-offence.json"
      }
    }
  },
  "required": [
    "hearingId",
    "offences"
  ],
  "additionalProperties": false
}
