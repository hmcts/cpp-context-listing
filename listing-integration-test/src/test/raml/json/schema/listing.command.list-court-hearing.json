{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id":  "http://justice.gov.uk/listing/courts/list-court-hearing.json",
  "type": "object",
  "properties": {
    "hearings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/hearingListingNeeds.json"
      }
    },
    "adjournedFromDate" : {
      "description": "Adjournment date",
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/datePattern"
    },
    "shadowListedOffences": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/domain/core/common/definitions.json#/definitions/uuid"
      }
    }
  },
  "required": [
    "hearings"
  ],
  "additionalProperties": false
}