{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "results": {
      "type": "integer"
    },
    "pageCount": {
      "type": "integer"
    },
    "courtCalendarHearings": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/hearing.json"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/notes.json"
      }
    }
  },
  "required": [
    "results",
    "pageCount",
    "courtCalendarHearings",
    "notes"
  ],
  "additionalProperties": false
}