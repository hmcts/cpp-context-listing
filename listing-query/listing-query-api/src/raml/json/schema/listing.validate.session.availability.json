{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/query/listing.validate.session.availability.json",
  "type": "object",
  "properties": {
    "results": {
      "type": "integer"
    },
    "pageCount": {
      "type": "integer"
    },
    "hearingSlots": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/court-schedule.json"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "results",
    "pageCount",
    "hearingSlots"
  ]
}
