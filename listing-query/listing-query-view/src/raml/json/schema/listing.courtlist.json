{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/query/listing.courtlist.json",
  "type": "object",
  "properties": {
    "courtList": {
      "type": "object",
      "properties": {
        "sittings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sittingDate": {
                "$ref": "#/definitions/localDate"
              },
              "courtRoomId": {
                "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
              },
              "judiciary": {
                "type": "array",
                "items": {
                  "$ref": "http://justice.gov.uk/listing/events/judicialRole.json"
                }
              },
              "hearings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "startTime": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "endTime": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "hearingType": {
                      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/hearingType"
                    },
                    "committingCourtCentreId": {
                      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
                    },
                    "caseIdentifier": {
                      "$ref": "listing-definitions.json#/definitions/caseIdentifier"
                    },
                    "defendants": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "$ref": "http://justice.gov.uk/listing/events/defendant.json"
                      }
                    }
                  },
                  "required": [
                    "startTime",
                    "endTime",
                    "hearingType",
                    "committingCourtCentreId",
                    "caseIdentifier",
                    "defendants"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "sittingDate",
              "courtRoomId",
              "judiciary",
              "hearings"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "courtList"
      ]
    }
  },
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "sittings"
  ],
  "additionalProperties": false
}
