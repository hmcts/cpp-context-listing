{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/defendant.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "personId": {
      "$ref": "http://justice.gov.uk/json/schemas/core/data-types.json#/definitions/uuid"
    },
    "firstName": {
      "description": "The person first name",
      "type": "string"
    },
    "lastName": {
      "description": "The person last name",
      "type": "string"
    },
    "dateOfBirth": {
      "description": "The person date of birth",
      "type": "string",
      "format": "date"
    },
    "bailStatus": {
      "enum": [
        "conditional",
        "unconditional",
        "inCustody"
      ]
    },
    "custodyTimeLimit": {
      "description": "Custody Time Limit",
      "type": "string",
      "format": "date"
    },
    "defenceOrganisation": {
      "type": "string"
    },
    "offences": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/offence.json"
      }
    }
  },
  "required": [
    "id",
    "personId",
    "firstName",
    "lastName",
    "dateOfBirth",
    "bailStatus",
    "defenceOrganisation",
    "offences"
  ],
  "additionalProperties":false
}
