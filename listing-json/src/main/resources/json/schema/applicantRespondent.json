{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/applicantRespondent.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "firstName": {
      "description": "The person first name",
      "type": "string"
    },
    "lastName": {
      "description": "The person last name",
      "type": "string"
    },
    "isRespondent": {
      "type": "boolean"
    },
    "restrictFromCourtList": {
      "type":"boolean"
    },
    "courtApplicationPartyType": {
      "description": "The type of court application party",
      "type": "string",
      "enum": [
        "PERSON",
        "ORGANISATION",
        "PROSECUTING_AUTHORITY",
        "PERSON_DEFENDANT"
      ]
    },
    "address": {
      "$ref": "http://justice.gov.uk/core/courts/address.json"
    },
    "masterDefendantId": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "dateOfBirth": {
      "description": "The date of birth of the party",
      "type": "string"
    }
  },
  "required": [
    "id",
    "lastName",
    "isRespondent",
    "courtApplicationPartyType"
  ],
  "additionalProperties": false
}
