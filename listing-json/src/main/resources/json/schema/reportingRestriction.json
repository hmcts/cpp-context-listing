{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/events/reportingRestriction.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "judicialResultId": {
      "description": "The shared result line identifier",
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "label": {
      "description": "The result label provided from reference data during the resulting process",
      "type": "string"
    },
    "orderedDate": {
      "description": "The date that the result was ordered",
      "$ref": "#/definitions/localDate"
    }
  },
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "id",
    "label"
  ],
  "additionalProperties": false
}