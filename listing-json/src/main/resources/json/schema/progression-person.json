{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/progression/events/progression-person.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/uuid"
    },
    "title": {
      "type": "string"
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "dateOfBirth": {
      "$ref": "#/definitions/datePattern"
    },
    "nationality": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "homeTelephone": {
      "type": "string"
    },
    "workTelephone": {
      "type": "string"
    },
    "mobile": {
      "type": "string"
    },
    "fax": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "address": {
      "$ref": "http://justice.gov.uk/progression/events/progression-address.json"
    }
  },
  "required": [
    "id"
  ],
  "definitions": {
    "datePattern": {
      "type": "string",
      "pattern": "^((([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13578]|1[02])\\-(0[1-9]|[12]\\d|3[01]))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-(0[13456789]|1[012])\\-(0[1-9]|[12]\\d|30))|(([\\+-]?\\d{4}(?!\\d{2}\\b))\\-02\\-(0[1-9]|1\\d|2[0-8]))|(((1[6-9]|[2-9]\\d)(0[48]|[2468][048]|[13579][26])|((16|[2468][048]|[3579][26])00))\\-02\\-29))$"
    }
  }
}
