{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.handler.update-hearing-for-listing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "type": {
      "$ref": "http://justice.gov.uk/core/courts/hearingType.json"
    },
    "startDate": {
      "$ref": "#/definitions/localDate"
    },
    "endDate": {
      "$ref": "#/definitions/localDate"
    },
    "nonSittingDays": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/localDate"
      }
    },
    "nonDefaultDays": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/commands/non-default-day.json"
      }
    },
    "jurisdictionType": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/jurisdictionType"
    },
    "judiciary": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/judicialRole.json"
      }
    },
    "hearingLanguage": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/hearingLanguage"
    }
  },
  "required": [
    "hearingId",
    "type",
    "startDate",
    "nonSittingDays",
    "nonDefaultDays",
    "jurisdictionType",
    "judiciary",
    "hearingLanguage",
    "courtCentreId"
  ],
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}