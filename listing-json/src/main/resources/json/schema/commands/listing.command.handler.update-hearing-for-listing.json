{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/listing.command.handler.update-hearing-for-listing.json",
  "type": "object",
  "properties": {
    "hearingId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtCentreId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "courtRoomId": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "type": {
      "$ref": "http://justice.gov.uk/core/courts/hearingType.json"
    },
    "startDate": {
      "$ref": "#/definitions/localDate"
    },
    "endDate": {
      "$ref": "#/definitions/localDate"
    },
    "weekCommencingStartDate": {
      "$ref": "#/definitions/localDate"
    },
    "weekCommencingEndDate": {
      "$ref": "#/definitions/localDate"
    },
    "weekCommencingDurationInWeeks": {
      "type": "integer"
    },
    "nonSittingDays": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/localDate"
      }
    },
    "nonDefaultDays": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/commands/non-default-day.json"
      }
    },
    "jurisdictionType": {
      "$ref": "http://justice.gov.uk/core/courts/jurisdictionType.json"
    },
    "judiciary": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/core/courts/judicialRole.json"
      }
    },
    "hearingLanguage": {
      "$ref": "http://justice.gov.uk/core/courts/hearingLanguage.json"
    },
    "hasVideoLink": {
      "type": "boolean"
    },
    "publicListNote": {
      "type": "string"
    },
    "selectedCourtCentre": {
      "$ref": "#/definitions/courtCentre"
    },
    "panel": {
      "description": "it can be Adult/Youth ",
      "type": "string"
    },
    "bookingType": {
      "description": "A choice of in-court, or video conference options",
      "type": "string"
    },
    "priority": {
      "description": "Priority marking on hearings/cases",
      "type": "string"
    },
    "specialRequirements": {
      "description": "Special requirements on hearings/cases",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string"
    },
    "startDateAndWeekCommencingOptional": {
      "type": "boolean"
    },
    "sendNotificationToParties": {
      "type": "boolean"
    },
    "splitHearing": {
      "type": "string"
    }
  },
  "required": [
    "hearingId",
    "type",
    "jurisdictionType",
    "judiciary",
    "hearingLanguage",
    "courtCentreId",
    "nonDefaultDays"
  ],
  "oneOf": [
    {
      "required": [
        "startDate",
        "nonSittingDays"
      ]
    },
    {
      "required": [
        "weekCommencingStartDate",
        "weekCommencingEndDate",
        "weekCommencingDurationInWeeks"
      ]
    },
    {
      "required": [
        "startDateAndWeekCommencingOptional"
      ]
    }
  ],
  "definitions": {
    "localDate": {
      "type": "string",
      "format": "date"
    },
    "courtCentre": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        },
        "courtRoomId": {
          "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
        }
      },
      "required": [
        "id",
        "courtRoomId"
      ]
    }
  },
  "additionalProperties": false
}