{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/defendant.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "datesToAvoid": {
      "type": "string"
    },
    "hearingLanguageNeeds": {
      "$ref": "http://justice.gov.uk/listing/events/listing-definitions.json#/definitions/hearingLanguage"
    },
    "specificRequirements": {
      "description": "The person special needs indicted any special needs that must be met by the courts process e.g. wheelchair access",
      "type": "string"
    },
    "firstName": {
      "description": "The person first name",
      "type": "string"
    },
    "lastName": {
      "description": "The person last name",
      "type": "string"
    },
    "dateOfBirth": {
      "description": "The person date of birth",
      "type": "string",
      "format": "date"
    },
    "bailStatus": {
      "description": "BailStatus of core domain with property of id,code,description",
      "$ref": "http://justice.gov.uk/core/courts/bailStatus.json"
    },
    "custodyTimeLimit": {
      "description": "Custody Time Limit",
      "type": "string",
      "format": "date"
    },
    "organisationName": {
      "description": "Where the defendant is an organisation",
      "type": "string"
    },
    "defenceOrganisation": {
      "type": "string"
    },
    "nationalityDescription": {
      "type": "string"
    },
    "address": {
      "$ref": "http://justice.gov.uk/core/courts/address.json"
    },
    "offences": {
      "type": "array",
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/offence.json"
      }
    },
    "isYouth": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "offences"
  ],
  "additionalProperties": false
}
