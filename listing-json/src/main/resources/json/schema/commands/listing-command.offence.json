{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/offence.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "offenceCode": {
      "type": "string"
    },
    "startDate": {
      "type": "string"
    },
    "endDate": {
      "type": "string"
    },
    "offenceWording": {
      "type": "string"
    },
    "statementOfOffence": {
      "$ref": "http://justice.gov.uk/listing/commands/statementOfOffence.json"
    },
    "custodyTimeLimit": {
      "$ref": "http://justice.gov.uk/listing/commands/custodyTimeLimit.json"
    },
    "laaApplnReference": {
      "$ref": "http://justice.gov.uk/listing/commands/laaReference.json"
    },
    "proceedingsConcluded": {
      "description": "Indicates that proceedings for the defendant have been concluded i.e. all offences have been disposed with final results or have been withdrawn by the prosecuting authority",
      "type": "boolean"
    },
    "isDiscontinued": {
      "description": "Determines that the offence has been discontinued by the prosecutor i.e. is no longer being proceeded with",
      "type": "boolean"
    },
    "isIntroduceAfterInitialProceedings": {
      "description": "Determines that the offence has been introduced by the prosecutor after proceeedings have already been initiated",
      "type": "boolean"
    },
    "reportingRestrictions": {
      "description": "Reporting restrictions",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "http://justice.gov.uk/listing/events/reportingRestriction.json"
      }
    },
    "seedingHearing" : {
      "$ref": "http://justice.gov.uk/listing/events/seedingHearing.json"
    }
  },
  "required": [
    "id",
    "offenceCode",
    "startDate",
    "offenceWording",
    "statementOfOffence"
  ],
  "additionalProperties": false
}
