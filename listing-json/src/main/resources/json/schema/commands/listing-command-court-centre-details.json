{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "id": "http://justice.gov.uk/listing/commands/court-centre-details.json",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/uuid"
    },
    "defaultStartTime": {
      "$ref": "#/definitions/localTime"
    },
    "defaultDuration": {
      "$ref": "http://justice.gov.uk/core/courts/courtsDefinitions.json#/definitions/positiveInteger"
    },
    "name" : {
      "type": "string"
    }
  },
  "required": [
    "id",
    "defaultStartTime",
    "defaultDuration"
  ],
  "definitions": {
    "localTime": {
      "type": "string",
      "format": "time"
    }
  },
  "additionalProperties": false
}
